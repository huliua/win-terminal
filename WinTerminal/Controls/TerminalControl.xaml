<UserControl x:Class="WinTerminal.Controls.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0C0C0C">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="OutputScroll" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Padding="10">
            <TextBlock x:Name="OutputText" FontFamily="Consolas, Courier New, monospace"
                       FontSize="14" Foreground="#CCCCCC"
                       TextWrapping="Wrap" AllowDrop="False"/>
        </ScrollViewer>

        <Grid VerticalAlignment="Bottom" Background="#0C0C0C">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="$ " FontFamily="Consolas, Courier New, monospace"
                       FontSize="14" Foreground="#16C60C" Margin="10,0,0,10"
                       VerticalAlignment="Center"/>

            <TextBox x:Name="InputBox" Grid.Column="1" Margin="0,0,10,10"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="14" Foreground="#CCCCCC"
                     Background="#0C0C0C" BorderThickness="0"
                     CaretBrush="White"
                     KeyDown="InputBox_KeyDown"/>
        </Grid>
    </Grid>
</UserControl>
