<UserControl x:Class="WinTerminal.Controls.CodexControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with navigation controls -->
        <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Codex GUI" FontSize="14"
                           Foreground="White" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>

                <Button x:Name="BtnBack" Grid.Column="1" Content="&#x2190;"
                        Width="30" Height="26" FontSize="14"
                        Background="{StaticResource BgLightBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnBack_Click" Margin="0,0,4,0"
                        ToolTip="Back"/>

                <Button x:Name="BtnForward" Grid.Column="2" Content="&#x2192;"
                        Width="30" Height="26" FontSize="14"
                        Background="{StaticResource BgLightBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnForward_Click" Margin="0,0,4,0"
                        ToolTip="Forward"/>

                <Button x:Name="BtnReload" Grid.Column="3" Content="&#x21BB;"
                        Width="30" Height="26" FontSize="14"
                        Background="{StaticResource BgLightBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnReload_Click" Margin="0,0,10,0"
                        ToolTip="Reload"/>

                <TextBox x:Name="UrlBox" Grid.Column="4"
                         Style="{StaticResource DarkInput}"
                         FontSize="12" Padding="6,4"
                         Text="https://chat.openai.com"
                         KeyDown="UrlBox_KeyDown"/>

                <Button x:Name="BtnGo" Grid.Column="5" Content="Go"
                        Style="{StaticResource SendButton}"
                        Padding="12,6" FontSize="12"
                        Click="BtnGo_Click" Margin="6,0,0,0"/>
            </Grid>
        </Border>

        <!-- WebBrowser -->
        <WebBrowser x:Name="Browser" Grid.Row="1"
                    Navigating="Browser_Navigating"
                    LoadCompleted="Browser_LoadCompleted"/>
    </Grid>
</UserControl>
